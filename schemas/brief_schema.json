{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "theme": {
      "type": "string",
      "enum": ["lessons", "corporate", "minimal"],
      "description": "Thème visuel"
    },
    "slides": {
      "type": "array",
      "minItems": 2,
      "maxItems": 12,
      "items": {
        "type": "object",
        "properties": {
          "template": {
            "type": "string",
            "enum": ["slide_intro.png", "slide_paragraph.png", "slide_bullets.png", "slide_cta.png", "slide_01.png", "slide_02.png"],
            "description": "Nom du fichier template"
          },
          "zones": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "description": "Contenu pour chaque zone définie dans zones.json"
          }
        },
        "required": ["template", "zones"]
      }
    },
    "platforms": {
      "type": "array",
      "items": { "type": "string", "enum": ["instagram", "linkedin"] },
      "default": ["instagram", "linkedin"]
    }
  },
  "required": ["theme", "slides"]
}
